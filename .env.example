# =============================================================================
# Classroom Supply Tracker — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your local environment.
# Never commit the .env file — it may contain secrets!
# =============================================================================

# ---- Backend (api-server / Vercel) ----

# Port the Express server listens on.
# Default: 5000
PORT=5000

# Environment mode. Set to "production" in deployment.
NODE_ENV=development

# Comma-separated origin(s) allowed for CORS requests.
# For local development this can be left empty (allows all origins).
# Example for production: https://your-app.github.io
CORS_ORIGIN=

# Secret key used to sign JWT tokens.
# In development a hardcoded fallback is used — but you should set one here.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Logging level: trace, debug, info, warn, error, fatal.
# Default: info
LOG_LEVEL=info


# ---- Frontend (classroom-tracker) ----

# API base URL for the frontend.
# When running locally, the Vite dev server proxies /api -> localhost:5000,
# so this can be left empty.
# Example for production: https://classroom-supply-tracker-api.onrender.com
VITE_API_URL=

# Base path where the app is served (used for GitHub Pages subpath deployment).
# Default: /
BASE_PATH=/

# Port the Vite dev server listens on.
# Default: 4173
PORT=4173
